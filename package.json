{
  "name": "electron-sparkle-updater",
  "version": "0.0.0",
  "type": "module",
  "license": "MIT",
  "description": "Sparkle-based auto-updates for Electron apps on macOS.",
  "engines": {
    "node": ">=20.19"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./builder": {
      "types": "./dist/builder.d.ts",
      "default": "./dist/builder.js"
    }
  },
  "bin": {
    "electron-sparkle-updater": "./bin/electron-sparkle-updater.js"
  },
  "files": [
    "dist",
    "bin",
    "native/src",
    "native/binding.gyp",
    "native/scripts",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "install": "node -e \"\"",
    "build": "tsc -p tsconfig.build.json",
    "prepublishOnly": "pnpm build",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "electron": ">=28"
  },
  "peerDependenciesMeta": {
    "electron": {
      "optional": true
    }
  },
  "dependencies": {
    "node-addon-api": "^8",
    "node-gyp": "^13"
  },
  "devDependencies": {
    "@types/node": "^22",
    "typescript": "^5",
    "vitest": "^3"
  }
}
